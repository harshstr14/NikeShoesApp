<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".homeScreen.NikeApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Nike">
        <activity
            android:name=".detailsScreen.DetailsScreen"
            android:exported="false"
            android:label="@string/title_activity_details_screen"
            android:theme="@style/Theme.Nike" />
        <activity
            android:name=".checkoutScreen.CheckoutScreen"
            android:exported="false"
            android:label="@string/title_activity_checkout_screen"
            android:theme="@style/Theme.Nike" />
        <activity
            android:name=".cartScreen.MyCartScreen"
            android:exported="false"
            android:label="@string/title_activity_my_cart_screen"
            android:theme="@style/Theme.Nike" />
        <activity
            android:name=".MainScreen"
            android:exported="false"
            android:label="@string/title_activity_main_screen"
            android:theme="@style/Theme.Nike" />
        <activity
            android:name=".ForgetPasswordScreen"
            android:exported="false"
            android:label="@string/title_activity_forget_password_screen"
            android:theme="@style/Theme.Nike" />
        <activity
            android:name=".SignUpScreen"
            android:exported="false"
            android:label="@string/title_activity_sign_up_screen"
            android:theme="@style/Theme.Nike" />
        <activity
            android:name=".SignInScreen"
            android:exported="false"
            android:label="@string/title_activity_sign_in_screen"
            android:theme="@style/Theme.Nike" />
        <activity
            android:name=".screens.ScreensActivity"
            android:exported="false"
            android:label="@string/title_activity_screens"
            android:theme="@style/Theme.Nike" />
        <activity
            android:name="com.yalantis.ucrop.UCropActivity"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Nike">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>